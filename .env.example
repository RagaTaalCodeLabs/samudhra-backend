# Gmail SMTP (use an App Password: Google Account → Security → 2-Step Verification → App passwords)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Set to true to log emails without connecting to SMTP (local dev)
FEE_REMINDER_DRY_RUN=false

# Student seeder (in-memory). Without SEED_ON_STARTUP or `npm run seed`, the student list starts empty.
SEED_ON_STARTUP=false
# Optional: 50–100 (values outside range are clamped)
SEED_STUDENT_COUNT=75
